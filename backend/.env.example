# .env.example — US Outdoor Navigator Backend
# Kopyala: cp .env.example .env  (gerçek değerleri doldur)

# ── Ortam ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development     # development | production

# ── Veri Dizini ────────────────────────────────────────────────────────────
# Local: ../data_sources (default)
# Railway/Render: /app/data_sources veya /opt/render/project/src/data_sources
DATA_DIR=../data_sources

# ── API Anahtarları (Opsiyonel) ────────────────────────────────────────────
# NASA FIRMS (wildfire) — ücretsiz: https://firms.modaps.eosdis.nasa.gov/api/
NASA_API_KEY=DEMO_KEY

# NOAA/NWS — API key gerektirmez (açık API)
# NOAA_USER_AGENT=USOutdoorNavigator/1.0 (contact@usoutdoor.app)

# ── CORS (Production'da frontend URL'ini ekle) ─────────────────────────────
# ALLOWED_ORIGINS=https://usoutdoor.app,https://app.usoutdoor.app

# ── Port ───────────────────────────────────────────────────────────────────
PORT=8000
