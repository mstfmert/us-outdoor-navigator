<?xml version="1.0" encoding="utf-8"?>
<!-- network_security_config.xml — Localhost geliştirme + güvenli üretim ayarları -->
<network-security-config>
    <!-- ── Geliştirme: localhost API (cleartext izni) ───────────────── -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- API production domain (HTTPS zorunlu) -->
        <!-- <domain includeSubdomains="true">api.usoutdoor.app</domain> -->
    </domain-config>
    <!-- ── Üretim: Tüm diğer bağlantılar HTTPS zorunlu ────────────── -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
